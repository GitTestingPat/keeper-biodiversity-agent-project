# =============================================================================
# BACKEND ENVIRONMENT VARIABLES - Biodiversity Agent
# Copiar a .env y completar los valores. NUNCA commitear el archivo .env real.
# =============================================================================

# ------------------------------
# API KEYS (CRÍTICO - Mantener secretos)
# ------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# APIs externas opcionales para datos reales (dejar vacío para modo simulación)
NASA_EARTHDATA_API_KEY=
OCEAN_OBSERVATORY_API_KEY=
WILDLIFE_CAMS_API_KEY=

# ------------------------------
# CONFIGURACIÓN DEL MODELO AI
# ------------------------------
# Modelos recomendados: openai:gpt-4o-mini, openai:gpt-4-turbo
AI_MODEL=openai:gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048

# ------------------------------
# SERVIDOR
# ------------------------------
HOST=127.0.0.1
PORT=8000
DEBUG=True

# ------------------------------
# RATE LIMITING
# ------------------------------
RATE_LIMIT=30
RATE_WINDOW=60

# ------------------------------
# CORS (Orígenes permitidos para el frontend)
# ------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ------------------------------
# SEGURIDAD
# ------------------------------
MAX_MESSAGE_LENGTH=2000

# ------------------------------
# ALERTAS (Configuración opcional de notificaciones)
# ------------------------------
# WEBHOOK_URL=https://tu-sistema-de-alertas/webhook
# EMAIL_RECIPIENTS=conservacion@org.org,emergencias@org.org

# =============================================================================
# ⚠️  SEGURIDAD:
# 1. Nunca commitear este archivo con valores reales
# 2. Usar variables de entorno del sistema en producción
# 3. Rotar API keys periódicamente
# =============================================================================